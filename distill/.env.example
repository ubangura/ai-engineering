ANTHROPIC_API_KEY=sk-ant-...
DEEPGRAM_API_KEY=...

# Railway provides this automatically; set manually for local dev
DATABASE_URL=postgresql://user:password@localhost:5432/lectern

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_COOKIE_SECRET=change-me-to-a-random-secret
# Netscape-formatted cookies file to bypass YouTube bot detection
YOUTUBE_COOKIES_PATH=/path/to/your/cookies.txt

# CORS origins for local dev (comma-separated). Leave empty in prod.
ALLOWED_ORIGINS=http://localhost:3000

# "development" or "production"
ENVIRONMENT=development
